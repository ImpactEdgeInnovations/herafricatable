# Browser-safe Supabase configuration
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Server-only. Use a Supabase sb_secret_ key. Never prefix with NEXT_PUBLIC_.
SUPABASE_SECRET_KEY=

# Canonical application URL. Use the production domain in Vercel Production.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Add these when the integrations are activated.
PAYSTACK_PUBLIC_KEY=
PAYSTACK_SECRET_KEY=
PAYSTACK_WEBHOOK_SECRET=
RESEND_API_KEY=
